# Junior Dev — environment template.
#
# Copy to .env for local dev:   cp .env.example .env
# Everything in section 1 is REQUIRED to run the app today. Everything else is
# commented out: each service has a dev fallback (mock/console/local-file), so
# leave a line commented until you actually have the credential — setting a
# placeholder value can switch code onto the "real adapter" path and break it.
# When a credential lands, also tick it off in ROADMAP.md -> "Needs from Sampo".

# ----------------------------- 1. Required now (M0-M2) -----------------------

# Postgres — matches docker-compose.yml's db service (docker compose up -d db).
DATABASE_URL=postgres://jrdev:jrdev@localhost:5432/jrdev

# Auth.js session/token signing secret. Generate your own:
#   npx auth secret        (or any 32+ byte random string)
AUTH_SECRET=change-me-generate-a-real-one

# Operator allowlist (M4) — comma-separated emails allowed to approve/reject
# pool drafts at /operator/pools. Unset = nobody is an operator (deny by default).
OPERATOR_EMAILS=operator@sussex.ac.uk

# ------------------------ 2. Real services (fill as they land) ---------------

# GitHub OAuth app (M2+) — real "Connect GitHub" instead of the mock connector.
# Create at: github.com -> Settings -> Developer settings -> OAuth Apps.
#   Homepage URL:            http://localhost:3000
#   Authorization callback:  http://localhost:3000/api/auth/callback/github
# While unset, dev uses a mock GitHub account (read-only scopes when real).
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=

# SMTP magic-link + notification delivery (M2 / launch). Discrete vars feed
# nodemailer's transport: port 587 = STARTTLS, 465 = implicit TLS.
# Selection: dev always uses the console + .dev/outbox.jsonl adapter (keeps the
# e2e suite hermetic); production auto-switches to SMTP when these are set;
# EMAIL_TRANSPORT=smtp|dev forces a choice. Check creds with: npm run email:verify
#EMAIL_HOST=smtp.your-provider.com
#EMAIL_PORT=587
#EMAIL_USER=noreply@yourdomain.dev
#EMAIL_PASS=
#EMAIL_FROM="Junior Dev <noreply@yourdomain.dev>"
#EMAIL_TRANSPORT=

# Anthropic API key (M12 battle-problem drafting, M17 pool-spec generation).
# While unset, the infra/ai client is mocked in tests; generation features are off.
#ANTHROPIC_API_KEY=

# Cloudflare Stream (M6 demo-video upload + signed playback).
# While unset, the dev video adapter stores uploads as local files.
#CLOUDFLARE_ACCOUNT_ID=
#CLOUDFLARE_STREAM_API_TOKEN=

# ---------------- 3. Self-hosted services (defaults, M12-M13) ----------------

# Judge0 code-execution sandbox (M12) — docker compose up judge0.
# Default matches the compose service; only change if you remap the port.
#JUDGE0_URL=http://localhost:2358

# Realtime WebSocket service (M13) — npm run dev:ws.
# NEXT_PUBLIC_* is exposed to the browser (it's where battle clients connect).
#NEXT_PUBLIC_WS_URL=ws://localhost:3001
#WS_PORT=3001

# --------------------------- 4. Production only (M18) ------------------------

# Canonical URL of the deployed app (Auth.js callback/link generation).
# Not needed locally — dev infers http://localhost:3000.
#AUTH_URL=https://yourdomain.dev

# Shared secret so only the host's cron scheduler can trigger pool lifecycle
# transitions over HTTP (the local pools:tick job runs without it).
#CRON_SECRET=
